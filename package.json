{
  "name": "@freelensapp/k8s-sre-assistant",
  "version": "0.3.1",
  "description": "Kubernetes SRE AI Assistant for Freelens - Chat with Ollama to manage and troubleshoot your clusters",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biurea/freelens-k8s-sre-assistant.git",
    "directory": "."
  },
  "main": "out/main/index.js",
  "renderer": "out/renderer/index.js",
  "files": [
    "out/**/*"
  ],
  "engines": {
    "node": ">= 22.0.0",
    "freelens": "^1.4.0"
  },
  "copyright": "© 2026 Freelens K8s SRE Assistant Authors",
  "license": "MIT",
  "author": {
    "name": "biurea",
    "email": "biurea@users.noreply.github.com"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "type:check": "tsc --noEmit -p tsconfig.json --composite false",
    "prebuild": "pnpm type:check",
    "build": "electron-vite build",
    "build:production": "VITE_PRESERVE_MODULES=false electron-vite build",
    "build:force": "electron-vite build",
    "pack:dev": "pnpm build:force && pnpm pack",
    "clean": "rm -rf out",
    "clean:all": "rm -rf out node_modules *.tgz"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@freelensapp/extensions": "^1.4.0",
    "@types/node": "~22.19.8",
    "@types/react": "^17.0.90",
    "@vitejs/plugin-react": "^5.1.3",
    "electron-vite": "^5.0.0",
    "mobx": "6.13.7",
    "mobx-react": "7.6.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sass": "^1.97.3",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-external": "^6.2.2",
    "vite-plugin-sass-dts": "^1.3.35"
  },
  "keywords": [
    "extension",
    "freelensapp",
    "freelens",
    "kubernetes",
    "sre",
    "ai",
    "ollama",
    "chatbot",
    "k8s"
  ],
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "node-pty"
    ]
  }
}
